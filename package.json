{
  "name": "@cloudflare/flagship-repo",
  "description": "The monorepo for Cloudflare's Flagship SDK and related packages",
  "type": "module",
  "keywords": [
    "cloudflare",
    "workers",
    "flagship"
  ],
  "author": "Cloudflare",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "pnpm -r run typecheck",
    "check": "sherif && oxfmt --check . && oxlint . && pnpm run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "sherif": "^1.11.1"
  },
  "packageManager": "pnpm@10.8.1",
  "overrides": {},
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css}": [
      "oxfmt --write"
    ]
  }
}
